___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const log = require('logToConsole');
const injectScript = require('injectScript');
const createArgumentsQueue = require('createArgumentsQueue');
const addConsentListener = require('addConsentListener');
const isConsentGranted = require('isConsentGranted');
const getUrl = require('getUrl');
const makeString = require('makeString');

const enableDebug = data.debug;
const debugLog = function(msg) {
  if (enableDebug) log('RUMvision GTM - ' + msg);
};

const propertyId = makeString(data.propertyId);
const hostname = data.hostnameOverride ? makeString(data.hostnameOverride) : getUrl('host');
const scriptUrl = 'https://d5yoctgpv4cpx.cloudfront.net/' + propertyId + '/v3-' + hostname + '.js';

// Initialise the rumv() command queue. Subsequent calls before the script
// loads are buffered into window.rumv.q and replayed once the script is ready.
const rumv = createArgumentsQueue('rumv', 'rumv.q');

// Optional: disable automatic submission so it can be triggered manually.
if (data.disableAuto) {
  rumv('config', { auto: false });
  debugLog('auto submit disabled');
}

// Map storage consent. RUMvision's default is denied (0); we only
// switch to 1 when the chosen consent strategy says we may store cookies.
const consentMode = data.consentMode || 'auto';

if (consentMode === 'always') {
  rumv('config', 'consent_storage', 1);
  debugLog('consent_storage = 1 (always)');
} else if (consentMode === 'never') {
  rumv('config', 'consent_storage', 0);
  debugLog('consent_storage = 0 (never)');
} else {
  // auto: follow GTM Consent Mode v2 analytics_storage signal.
  rumv('config', 'consent_storage', 0);
  if (isConsentGranted('analytics_storage')) {
    rumv('config', 'consent_storage', 1);
    debugLog('analytics_storage already granted');
  } else {
    debugLog('analytics_storage denied, listening for change');
    addConsentListener('analytics_storage', function(consentType, granted) {
      if (granted) {
        rumv('config', 'consent_storage', 1);
        debugLog('analytics_storage now granted');
      }
    });
  }
}

debugLog('Loading ' + scriptUrl);

injectScript(scriptUrl, function() {
  debugLog('Script loaded');
  data.gtmOnSuccess();
}, function() {
  debugLog('Script failed to load');
  data.gtmOnFailure();
}, 'rumvision-' + propertyId);


